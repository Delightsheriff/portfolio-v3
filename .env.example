# Sanity CMS Configuration
# Get these values from https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API Token (optional, for published content only)
# Generate at https://sanity.io/manage > API > Tokens
SANITY_API_READ_TOKEN=your_read_token_here_optional

# Deployment Environment
# Used by Next.js and Vercel to detect build vs. runtime
NODE_ENV=development

# Optional: For analytics, monitoring, or webhooks
# Add your own integrations here as needed
# SEGMENT_WRITE_KEY=your_segment_key
# SENTRY_DSN=your_sentry_dsn
# SLACK_WEBHOOK_URL=your_slack_webhook
